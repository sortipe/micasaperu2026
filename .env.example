# Configuración de Culqi para Pagos con Tarjeta
# Reemplaza estos valores con las llaves de tu cuenta de Culqi (https://culqi.com)
VITE_CULQI_PUBLIC_KEY=pk_test_...
CULQI_PRIVATE_KEY=sk_test_...

# Otras variables de entorno
VITE_SUPABASE_URL=...
VITE_SUPABASE_ANON_KEY=...

# Google Tag Manager y Google Analytics
# Reemplaza con los IDs de tu cuenta de Google Tag Manager y Google Analytics
VITE_GTM_ID=GTM-XXXXXXX
VITE_GA4_ID=G-XXXXXXXXXX
