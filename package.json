{
  "name": "micasaperu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "npx serve -s dist -l 3000",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.micasaperu.app",
    "productName": "Mi Casa Peru",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.38.0",
    "@mercadopago/sdk-react": "^1.0.7",
    "@supabase/supabase-js": "2",
    "@tailwindcss/vite": "^4.2.1",
    "@turf/turf": "^7.3.4",
    "@types/leaflet": "^1.9.21",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.35.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "swiper": "^12.1.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
